rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config
    // Document ID: 'default'
    // Fields:
    //   - event_name: string (required)
    //   - event_date: string (required)
    //   - require_phone: boolean (required)
    //   - require_company: boolean (required)
    //   - logo_url: string (optional)
    // Document ID: 'voting'
    // Fields:
    //   - categories: list of strings
    //
    // Collection: teams
    // Document ID: auto-generated
    // Fields:
    //   - name: string
    //   - manual_points: number
    //   - created_at: timestamp
    //
    // Collection: votes
    // Document ID: auto-generated
    // Fields:
    //   - team_id: string
    //   - voter_name: string
    //   - scores: map
    //   - total_score: number
    //   - created_at: timestamp
    //
    // Collection: registrations
    // Document ID: auto-generated
    // Fields:
    //   - barcode_id: string (required, length 8)
    //   - name: string (required, length > 0)
    //   - department: string (required, length > 0)
    //   - phone: string (optional)
    //   - company: string (optional)
    //   - checked_in: boolean (required)
    //   - created_at: timestamp (required)
    //
    // Collection: users
    // Document ID: user email
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin')
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "WIDoZopjAycoQXLQcP6GOLQH0DH2" ||
        request.auth.token.email == "adrianazwal47@gmail.com" ||
        request.auth.token.email == "Adrianazwal47@gmail.com"
      );
    }

    match /{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == "WIDoZopjAycoQXLQcP6GOLQH0DH2";
    }

    function isValidVote() {
      return request.resource.data.team_id is string && 
             request.resource.data.voter_name is string && 
             request.resource.data.scores is map &&
             request.resource.data.total_score is number;
    }

    match /config/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /votes/{voteId} {
      allow read, list: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    match /users/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
